{
        "gtk-layer-shell": false,
	"layer": "top",
	"modules-left": ["custom/launcher","cpu","memory","custom/media","tray"],
	//"modules-center": ["wlr/workspaces"],
	"modules-center": ["sway/workspaces"],
	"modules-right": ["backlight","pulseaudio", "network", "clock", "battery","custom/power"],
	
	"pulseaudio": {
               "tooltip": false,
               "scroll-step": 1,
               "format": " {icon} {volume}%",
               "format-muted": " ґ░ЦБ {volume}%",
               "format-icons": {
                "default": ["ґ░Х┐", "ґ░ЦА", "ґ░Х╛"]
              },
              "on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle"
	},
        "river/tags": {
                    "num-tags": 6,
                    "disable-click": true,
        },
        //"wlr/workspaces": {
        //  "sort-by-name": true,
        //  /* "on-click": "activate", */
        //},

		"sway/workspaces": {
			"disable-scroll": true,
			"disable-markup" : false,
			"all-outputs": true,
			"format": "  {icon}  ",
			//"format":"{icon}",
			"format-icons": {
				"1": "яДа",
				"2": "яЙй",
				"3": "юЯЕ",
				"4": "ґ░ОИ",
			}
		},


	"network": {
		"tooltip": false,
                "format": "{icon}",
                "format-alt": "{ipaddr} {icon}",
                "format-alt-click": "click-right",
                "format-icons": {
                  "wifi": ["яЗл"],
                  "ethernet": ["ґ░ИА"],
                  "disconnected": ["ґ░Цк"],
                },
                "on-click": "xfce4-terminal -e nmtui",
	},
	"backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": ["юПХ", "юПЦ", "юПШ", "юПЪ", "юПЪ", "юПЮ", "юПа", "юПв", "юПг"],
        "on-click": "",
        "on-scroll-up": "brightnessctl -c backlight set 1%-",
        "on-scroll-down": "brightnessctl -c backlight set +1%",
        "smooth-scrolling-threshold": 1,
	},
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "яЗж {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
	"tray":{
		"icon-size":18,
		"spacing": 10
	},
    "clock": {
        "format": "{:юОД %H:%M }",
		"format-alt": "{:юОД %H:%M  яБ│ %d/%m/%Y}"
    },
    "cpu": {
        "interval": 15,
        "format": "яЛЫ {}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": "яГЙ {}%",
        "max-length": 10
    },
    "custom/media": {
        "interval": 30,
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 20,
        "format-icons": {
            "spotify": "яЖ╝ ",
            "default": "ґ░ОИ "
        },
        "escape": true,
        "exec": "$HOME/.config/system_scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause"
    },
    "custom/launcher":{
        "format": "яМГ",
        "on-click": "exec wofi -c ~/.config/wofi/config -I",
        "on-click-right": "killall wofi"
    },
    "custom/power":{
        "format": "тП╗",
        /* "on-click": "bash ~/.config/rofi/leave/leave.sh", */
        /* "on-click":"rofi-powermenu" */
        "on-click": "wlogout -p layer-shell"
    },
    "custom/updates":{
        "format": "{} Update(s)",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "kitty -e yay -Syu && notify-send 'The system has been updated' "
    },
    /*"custom/wallpaper":{
        "format":"яА╛ ",
        "on-click": "bash ~/.config/system_scripts/pkill_bc"
    }*/
}
