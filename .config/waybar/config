{
        "gtk-layer-shell": false,
	"layer": "top",
	"modules-left": ["custom/launcher","cpu","memory","custom/media","tray"],
	"modules-center": ["wlr/workspaces"],
	"modules-right": ["backlight","pulseaudio", "network", "clock", "battery","custom/power"],
	
	"pulseaudio": {
               "tooltip": false,
               "scroll-step": 5,
               "format": " {icon} {volume}%",
               "format-muted": " ´¬Ç {volume}%",
               "format-icons": {
                "default": ["´®¥", "´®┐", "´®¢"]
              },
              "on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle"
	},
        "river/tags": {
                    "num-tags": 6,
                    "disable-click": true,
        },
        "wlr/workspaces": {
          "sort-by-name": true,
          /* "on-click": "activate", */
        },

	"network": {
		"tooltip": false,
                "format": "{icon}",
                "format-alt": "{ipaddr} {icon}",
                "format-alt-click": "click-right",
                "format-icons": {
                  "wifi": ["´ç½"],
                  "ethernet": ["´ø┐"],
                  "disconnected": ["´¬®"],
                },
                "on-click": "xfce4-terminal -e nmtui",
	},
	"backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": ["´ùØ", "´ù£", "´ùŞ", "´ùş"],
        "on-click": "",
        "on-scroll-up": "brightnessctl -c backlight set 1%-",
        "on-scroll-down": "brightnessctl -c backlight set +1%",
        "smooth-scrolling-threshold": 1,
	},
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "´çĞ {capacity}%",
        "format-plugged": "´çĞ {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
	"tray":{
		"icon-size":18,
		"spacing": 10
	},
    "clock": {
        "format": "{:¯Ää %H:%M }",
		"format-alt": "{:¯Ää %H:%M %S  ´ùÁ %d/%m/%Y}"
    },
    "cpu": {
        "interval": 15,
        "format": "´ïø {}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": "´âë {}%",
        "max-length": 10
    },
    "custom/media": {
        "interval": 30,
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 20,
        "format-icons": {
            "spotify": "´å╝ ",
            "default": "´óà "
        },
        "escape": true,
        "exec": "$HOME/.config/system_scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause"
    },
    "custom/launcher":{
        "format": "´îâÔÇë",
        "on-click": "exec wofi -c ~/.config/wofi/config -I",
        "on-click-right": "killall wofi"
    },
    "custom/power":{
        "format": "ÔÅ╗",
        /* "on-click": "bash ~/.config/rofi/leave/leave.sh", */
        /* "on-click":"rofi-powermenu" */
        "on-click": "wlogout -p layer-shell"
    },
    "custom/updates":{
        "format": "{} Update(s)",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "kitty -e yay -Syu && notify-send 'The system has been updated' "
    },
    /*"custom/wallpaper":{
        "format":"´Ç¥ ",
        "on-click": "bash ~/.config/system_scripts/pkill_bc"
    }*/
}
